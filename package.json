{
  "name": "projects",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "corepack pnpm install --prefer-frozen-lockfile --prod=false && next build && tsup src/server.ts --format cjs --platform node --target node20 --outDir dist --no-splitting --no-minify",
    "dev": "tsx watch src/server.ts",
    "preinstall": "npx only-allow pnpm",
    "analyze:crawlers": "node scripts/analyze-crawler-logs.mjs",
    "lint": "eslint",
    "preview:local": "node scripts/quick-preview.mjs start",
    "preview:local:logs": "node scripts/quick-preview.mjs logs",
    "preview:local:serve": "node scripts/quick-preview.mjs serve",
    "preview:local:status": "node scripts/quick-preview.mjs status",
    "preview:local:stop": "node scripts/quick-preview.mjs stop",
    "seo:pipeline": "node scripts/seo-full-pipeline.mjs",
    "start": "node dist/server.js",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "ts-check": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "only-allow": "^1.2.2",
    "playwright": "^1.60.0",
    "shadcn": "latest",
    "tailwindcss": "^4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  }
}
